generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  RECEPTIONIST
  TECHNICIAN
}

enum TicketStatus {
  ABIERTO
  RESPONDIDO
  CERRADO
}

enum DerivacionStatus {
  PENDIENTE
  CARGADA
  ANULADA
}

enum OrderStatus {
  CREADA
  EN_ESPERA
  EN_ATENCION
  PROCESANDO
  LISTO_PARA_ENTREGA
  ENTREGADA
  ANULADA
  ENVIADA_DIGITAL
  DEMORADA
}

enum PaymentMethod {
  EFECTIVO
  TARJETA_DEBITO
  TARJETA_CREDITO
  TRANSFERENCIA
  MERCADOPAGO
  CUENTA_CORRIENTE
  OTRO
  SALDO
}

enum DailyRegisterStatus {
  ABIERTA
  CIERRE_PARCIAL
  CERRADA
}

enum MovementType {
  GASTO
  RETIRO
  INGRESO_EXTRA
  A_CAJA_FUERTE  
  RETIRO_DUENO   
}

model Branch {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  address        String?
  phone          String?
  isActive       Boolean         @default(true)

  users          User[]
  orders         Order[]
  equipments     Equipment[]
  cashMovements  CashMovement[]
  technicianProfiles TechnicianProfile[]

  dailyRegisters DailyRegister[]
  safeVault      SafeVault?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TechnicianProfile {
  id       String  @id @default(cuid())
  name     String
  branchId String
  branch   Branch  @relation(fields: [branchId], references: [id])
  isActive Boolean @default(true)
  orders   Order[]

  createdAt DateTime @default(now())
}

model DailyRegister {
  id            String              @id @default(cuid())
  branchId      String
  branch        Branch              @relation(fields: [branchId], references: [id])
  
  date          DateTime            @default(now()) 
  status        DailyRegisterStatus @default(ABIERTA)
  
  startBalance  Decimal             @default(0)
  endBalance    Decimal?
  
  openedBy      String              
  closedBy      String?             
  notes         String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([branchId, date]) 
}

model SafeVault {
  id          String   @id @default(cuid())
  branchId    String   @unique
  branch      Branch   @relation(fields: [branchId], references: [id])
  balance     Decimal  @default(0)
  updatedAt   DateTime @updatedAt
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  pin               String                      // Legacy - kept for backward compat during migration
  password          String?                     // New field - replaces pin gradually
  mustResetPassword Boolean  @default(false)    // true = force password change on next login
  firstName         String
  lastName          String
  role              UserRole @default(RECEPTIONIST)
  isActive          Boolean  @default(true)

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Equipment {
  id         String      @id @default(cuid())
  name       String
  type       String?  
  
  room       String?  
  anydeskId  String?  
  ipAddress  String?  
  
  branchId   String
  branch     Branch      @relation(fields: [branchId], references: [id])

  orderItems OrderItem[]

  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())

  @@unique([branchId, name])
}

model Patient {
  id                  String      @id @default(cuid())
  dni                 String      @unique
  firstName           String?
  lastName            String?
  birthDate           DateTime?
  phone               String?
  email               String?
  affiliateNumber     String?
  plan                String?   
  
  defaultObraSocialId String?
  defaultObraSocial   ObraSocial? @relation(fields: [defaultObraSocialId], references: [id])

  orders              Order[]

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Dentist {
  id                 String   @id @default(cuid())
  firstName          String
  lastName           String
  matriculaProv      String?  
  matriculaNac       String?  
  email              String?
  phone              String?
  
  resultPreference   String? 
  deliveryMethod     String? 
  
  orders             Order[]
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  password           String?
  mustChangePassword Boolean  @default(true)

  tickets            Ticket[]
  derivaciones       Derivacion[]
}

model ObraSocial {
  id                String     @id @default(cuid())
  name              String
  code              String?    @unique
  maxAgeOrtodoncia  Int?

  priceListId String?
  priceList   PriceList? @relation(fields: [priceListId], references: [id])

  variants    ObraSocialVariant[]
  orders      Order[]
  patients    Patient[]

  isActive    Boolean    @default(true)
}

model ObraSocialVariant {
  id            String     @id @default(cuid())
  name          String
  obraSocialId  String
  obraSocial    ObraSocial @relation(fields: [obraSocialId], references: [id], onDelete: Cascade)
  orders        Order[]    @relation("OrderVariant")

  @@index([obraSocialId])
}

model Procedure {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  category      String?
  
  requiresTooth   Boolean     @default(false)
  options         String[]    @default([])
  extraPhotoPrice Float       @default(0)

  prices        Price[]
  orderItems    OrderItem[]

  isActive      Boolean     @default(true)
}

model PriceList {
  id            String       @id @default(cuid())
  name          String
  
  obrasSociales ObraSocial[]
  prices        Price[]

  isActive      Boolean      @default(true)
}

model Price {
  id                String    @id @default(cuid())
  amount            Decimal
  insuranceCoverage Decimal   @default(0)
  patientCopay      Decimal   @default(0)
  customCode        String?

  priceListId       String
  priceList         PriceList @relation(fields: [priceListId], references: [id])
  
  procedureId       String
  procedure         Procedure @relation(fields: [procedureId], references: [id])

  @@unique([priceListId, procedureId])
}

model Order {
  id              String         @id @default(cuid())
  dailyId         Int            @default(autoincrement())
  code            String?        @unique

  branchId        String
  branch          Branch         @relation(fields: [branchId], references: [id])

  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])

  dentistId       String?
  dentist         Dentist?       @relation(fields: [dentistId], references: [id])

  obraSocialId    String?
  obraSocial      ObraSocial?    @relation(fields: [obraSocialId], references: [id])

  osVariantId     String?
  osVariant       ObraSocialVariant? @relation("OrderVariant", fields: [osVariantId], references: [id])

  technicianId    String?
  technician      TechnicianProfile? @relation(fields: [technicianId], references: [id])

  status          OrderStatus    @default(CREADA)
  accessCode      String?        @unique @default(uuid())
  images          String[]       @default([])
  externalLink    String?
  
  equipmentName   String?     
  
  createdAt       DateTime       @default(now())
  attendedAt      DateTime?
  completedAt     DateTime?
  deliveredAt     DateTime?

  totalAmount     Decimal        @default(0)
  patientAmount   Decimal        @default(0)
  insuranceAmount Decimal        @default(0)
  paidAmount      Decimal        @default(0)
  
  items           OrderItem[]
  payments        Payment[]
  history         OrderHistory[]

  notes           String?
  deliveryMethod  String?

  recipeChecked   Boolean        @default(false)
  recipeCheckedAt DateTime?
  recipeCheckedBy String?

  updatedAt       DateTime       @updatedAt

  @@index([branchId, status])
  @@index([patientId])
  @@index([createdAt])
}

model OrderItem {
  id                String      @id @default(cuid())
  
  orderId           String
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  procedureId       String
  procedure         Procedure   @relation(fields: [procedureId], references: [id])

  equipmentId       String?
  equipment         Equipment?  @relation(fields: [equipmentId], references: [id])

  price             Decimal
  insuranceCoverage Decimal     @default(0)
  patientCopay      Decimal     @default(0)
  
  metadata          Json?     
  
  details           Json?
  status            OrderStatus @default(CREADA)

  createdAt         DateTime    @default(now())
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  amount    Decimal
  method    PaymentMethod
  notes     String?

  createdAt DateTime      @default(now())
}

model OrderHistory {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  userId    String?
  action    String
  oldStatus OrderStatus?
  newStatus OrderStatus?
  details   String?

  createdAt DateTime     @default(now())
}

model CashMovement {
  id          String        @id @default(cuid())
  
  branchId    String
  branch      Branch        @relation(fields: [branchId], references: [id])
  
  type        MovementType
  amount      Decimal
  description String
  method      PaymentMethod @default(EFECTIVO)
  
  createdAt   DateTime      @default(now())
  
  @@index([branchId, createdAt])
}
model Ticket {
  id          String       @id @default(cuid())
  dentistId   String
  dentist     Dentist      @relation(fields: [dentistId], references: [id])
  subject     String
  message     String
  status      TicketStatus @default(ABIERTO)
  reply       String?
  repliedAt   DateTime?
  repliedBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([dentistId])
}

model Derivacion {
  id               String           @id @default(cuid())
  prescriptionCode String           @unique

  dentistId        String
  dentist          Dentist          @relation(fields: [dentistId], references: [id])

  patientApellido  String
  patientNombre    String
  patientDni       String?
  patientBirthDate String?
  cobertura        String           @default("particular")
  obraSocial       String?
  nroAfiliado      String?

  procedures       Json
  indicaciones     String?

  status           DerivacionStatus @default(PENDIENTE)
  usedAt           DateTime?

  createdAt        DateTime         @default(now())

  @@index([prescriptionCode])
  @@index([dentistId])
  @@index([createdAt])
}
